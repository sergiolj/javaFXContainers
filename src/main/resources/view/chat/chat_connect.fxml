<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ucsal.sergiolj.containers.chat.gui.controller.ConnectController">
    <GridPane hgap="10.0" vgap="10.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <Label text="User Name" />
        <TextField fx:id="txf_user_name" GridPane.columnIndex="1" />
        <Label text="Server Name" GridPane.rowIndex="1" />
      <ChoiceBox fx:id="chbox_servers_list" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>
    <HBox alignment="CENTER" spacing="20.0">
        <padding>
            <Insets bottom="20.0" />
        </padding>
        <Button mnemonicParsing="false" onAction="#closeWindow" prefWidth="100.0" text="Cancel" />
        <Button mnemonicParsing="false" onAction="#connectToServer" prefWidth="100.0" text="Connect" />
    </HBox>
</VBox>
